{
  "publisher": "Alaeddinezorgui",
  "id": "nice-on-success",
  "name": "nice-on-success",
  "displayName": "NICE on Success",
  "description": "Plays random celebratory sounds on task/command success and failure. Customize sounds and filter triggers.",
  "version": "1.0.2",
  "icon": "logo/logo.png",
  "keywords": [
    "sound",
    "notification",
    "task",
    "test",
    "fun",
    "meme",
    "audio",
    "feedback"
  ],
  "categories": [
    "Other",
    "Testing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zorguiala/NICE-on-success"
  },
  "homepage": "https://github.com/zorguiala/NICE-on-success",
  "bugs": {
    "url": "https://github.com/zorguiala/NICE-on-success/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "niceOnSuccess.playSuccess",
        "title": "NICE: Play Success Sound"
      },
      {
        "command": "niceOnSuccess.playFailure",
        "title": "NICE: Play Failure Sound"
      },
      {
        "command": "niceOnSuccess.addCommand",
        "title": "NICE: Add Command to Filter"
      },
      {
        "command": "niceOnSuccess.removeCommand",
        "title": "NICE: Remove Command from Filter"
      },
      {
        "command": "niceOnSuccess.listCommands",
        "title": "NICE: Show Enabled Commands"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "NICE on Success",
      "properties": {
        "niceOnSuccess.successSoundPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the custom .wav file to play on success."
        },
        "niceOnSuccess.failureSoundPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the custom .wav file to play on failure."
        },
        "niceOnSuccess.enabledTasks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Array of task names to play sounds for. Leave empty to play sounds for all tasks. Example: [\"npm: test\", \"npm: build\"]"
        },
        "niceOnSuccess.enableTerminalListener": {
          "type": "boolean",
          "default": false,
          "description": "Enable sounds for terminal commands (requires VS Code 1.89.0+). Disable to only play sounds for tasks."
        },
        "niceOnSuccess.minDurationMs": {
          "type": "number",
          "default": 100,
          "description": "Minimum execution time (in milliseconds) a task or command must run before a sound is triggered. Keeps the extension quiet for practically instantaneous commands like 'clear'."
        },
        "niceOnSuccess.enabledTerminalCommands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Array of terminal commands to play sounds for (e.g. [\"npm\", \"build\"]). Only used when enableTerminalListener is true. Leave empty to play sounds for all commands."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --out zorguiala.nice-on-success.vsix"
  },
  "sponsorLink": "https://github.com/sponsors/zorguiala",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ]
}